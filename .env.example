# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sinch Conversation API
SINCH_PROJECT_ID=your-sinch-project-id
SINCH_APP_ID=your-sinch-app-id
SINCH_KEY_ID=your-sinch-key-id
SINCH_KEY_SECRET=your-sinch-key-secret
SINCH_WEBHOOK_SECRET=your-sinch-webhook-secret

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Cron Authentication
CRON_SECRET=generate-a-random-64-char-string

# Rate Limiting (Upstash Redis) — optional, limits disabled without these
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Sentry — optional
SENTRY_DSN=https://your-dsn@sentry.io/project
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project

# Axiom — optional
AXIOM_DATASET=dealershipiq
AXIOM_TOKEN=your-axiom-token
