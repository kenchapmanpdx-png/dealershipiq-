# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-key  # Used in middleware for JWT verification

# Stripe (Phase 5 — Billing)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID=price_your_stripe_price_id  # Used in stripe.ts for billing operations
NEXT_PUBLIC_BASE_URL=http://localhost:3000    # Canonical app URL (also reads NEXT_PUBLIC_APP_URL as legacy alias)
NEXT_PUBLIC_APP_URL=http://localhost:3000    # Alternative app URL reference used in various places

# Sinch Conversation API
SINCH_PROJECT_ID=your-sinch-project-id
SINCH_APP_ID=your-sinch-app-id
SINCH_KEY_ID=your-sinch-key-id
SINCH_KEY_SECRET=your-sinch-key-secret
SINCH_WEBHOOK_SECRET=your-sinch-webhook-secret
SINCH_PHONE_NUMBER=+1234567890  # Sender phone number for outbound SMS (used in sms.ts)
SINCH_SERVICE_PLAN_ID=your-sinch-service-plan-id  # Service plan for SMS REST API
SINCH_API_TOKEN=your-sinch-api-token  # API token for SMS REST API authentication
# S2: Shared-secret required on every XMS (REST API) inbound webhook. Configure
# in the Sinch dashboard as an extra header `X-Sinch-Webhook-Token: <value>`.
# Must be a high-entropy random string (e.g. openssl rand -hex 32).
SINCH_XMS_CALLBACK_TOKEN=generate-a-random-64-char-string

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
# Model overrides — optional. Defaults live in src/lib/openai.ts (OPENAI_MODELS).
# To upgrade when OpenAI ships a better model: set the new PINNED snapshot ID
# here (or in Vercel -> Settings -> Environment Variables) and redeploy.
# No code change needed. Spot-check grading scores after any swap.
# OPENAI_MODEL_PRIMARY=gpt-5.4-2026-03-05      # grading, follow-ups, scenario generation
# OPENAI_MODEL_FALLBACK=gpt-4o-mini-2024-07-18 # grading fallback, classify, compaction
# OPENAI_MODEL_COACH=gpt-4o-2024-11-20         # Ask IQ coach conversations
# OPENAI_TIMEOUT_MS=10000                      # per-call timeout for grading/follow-ups

# Cron Authentication
# 2026-04-18 C-5: MUST be a high-entropy value. Generate with:
#   openssl rand -hex 32
# Do NOT use human-readable values like "dealershipiq-cron-secret-2024" —
# `timingSafeEqual` is worthless against a guessable secret.
CRON_SECRET=generate-a-random-64-char-string

# Admin API Key — gates /api/admin/* and any service-level cross-tenant tooling.
# 2026-04-18 C-5: MUST be a high-entropy value. Generate with:
#   openssl rand -hex 32
ADMIN_API_KEY=generate-a-random-64-char-string

# Internal worker secret — gates server-to-server calls to /api/internal/*.
# 2026-04-18 H-1: the Sinch webhook dispatches inbound messages to
# /api/internal/sinch-process via fire-and-forget fetch. That route trusts
# the shared secret as proof that upstream Sinch auth already succeeded.
# MUST be a high-entropy value. Generate with:
#   openssl rand -hex 32
INTERNAL_WORKER_SECRET=generate-a-random-64-char-string

# SMS Control
# S10: allow-list gate. MUST equal the literal string "true" to enable live SMS.
# Any other value (missing, empty, "false", "yes", "1") disables sending. Safe default.
ENABLE_SMS_SEND=true

# Red-flag manager alerts ("X needs attention" SMS, sent by /api/cron/red-flag-check
# every 6 hours). PAUSED unless this equals the literal string "true".
# Detection still runs and persists to red_flag_events regardless.
RED_FLAG_SMS_ENABLED=false

# Coach Mode Auth (Phase 4.5A)
APP_TOKEN_SECRET=generate-a-random-64-char-string  # Signs PWA session tokens for Coach Mode

# Rate Limiting (Upstash Redis) — optional, limits disabled without these
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Sentry — optional
SENTRY_DSN=https://your-dsn@sentry.io/project
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project
SENTRY_AUTH_TOKEN=sntrys_your-auth-token       # For source map uploads during build
SENTRY_ORG=dealershipiq
SENTRY_PROJECT=dealershipiq-nextjs

# Axiom — optional
AXIOM_DATASET=dealershipiq
AXIOM_TOKEN=your-axiom-token
