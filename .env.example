# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (Phase 5 — Billing)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_BASE_URL=http://localhost:3000    # Canonical app URL (also reads NEXT_PUBLIC_APP_URL as legacy alias)

# Sinch Conversation API
SINCH_PROJECT_ID=your-sinch-project-id
SINCH_APP_ID=your-sinch-app-id
SINCH_KEY_ID=your-sinch-key-id
SINCH_KEY_SECRET=your-sinch-key-secret
SINCH_WEBHOOK_SECRET=your-sinch-webhook-secret

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Cron Authentication
CRON_SECRET=generate-a-random-64-char-string

# SMS Control
ENABLE_SMS_SEND=true              # Gate for outbound SMS — set false to disable all sends

# Coach Mode Auth (Phase 4.5A)
APP_TOKEN_SECRET=generate-a-random-64-char-string  # Signs PWA session tokens for Coach Mode

# Rate Limiting (Upstash Redis) — optional, limits disabled without these
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Sentry — optional
SENTRY_DSN=https://your-dsn@sentry.io/project
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project
SENTRY_AUTH_TOKEN=sntrys_your-auth-token       # For source map uploads during build
SENTRY_ORG=dealershipiq
SENTRY_PROJECT=dealershipiq-nextjs

# Axiom — optional
AXIOM_DATASET=dealershipiq
AXIOM_TOKEN=your-axiom-token
